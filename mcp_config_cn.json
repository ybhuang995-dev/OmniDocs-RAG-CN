{
  "_comment": "OmniDocs-RAG-CN MCP 配置模板 — 复制到 IDE 的 MCP 配置文件中使用",
  "mcpServers": {
    "omnidocs-rag-cn": {
      "command": "python",
      "args": [
        "<你的项目路径>/OmniDocs-RAG-CN/server.py"
      ],
      "env": {
        "RAG_DOCS_PATH": "<你要索引的文档目录>",
        "RAG_DB_PATH": "<你的项目路径>/OmniDocs-RAG-CN/chroma_db",
        "HF_ENDPOINT": "https://hf-mirror.com",
        "HF_HUB_OFFLINE": "0",
        "TRANSFORMERS_OFFLINE": "0"
      }
    }
  }
}
